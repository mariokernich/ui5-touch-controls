{
  "compilerOptions": {
    "target": "es2023",
    "module": "es2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "rootDir": "./",
    "types": ["@openui5/types"],
    "paths": {
      "ui5/sized/controls/*": ["./src/ui5/sized/controls/*"]
    }
  },
  "include": ["./src/**/*", "./test/**/*"]
}
