{
  "name": "ui5.touch.controls",
  "version": "1.0.0",
  "description": "UI5 Library: ui5.touch.controls",
  "author": "Mario Kernich",
  "license": "Apache-2.0",
  "types": "dist/index.d.ts",
  "files": [
    ".eslintrc.js",
    "LICENCE",
    "README.md",
    "tsconfig.json",
    "ui5.yaml",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "src",
    "test"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build:icon-font": "node scripts/build-icon-font.mjs",
    "prebuild": "npm run build:icon-font",
    "build": "ui5 build --clean-dest",
    "prebuild:self-contained": "npm run build:icon-font",
    "build:self-contained": "ui5 build self-contained --all --config ui5-self-contained.yaml --clean-dest",
    "build:ts-interfaces": "npx @ui5/ts-interface-generator",
    "prestart": "npm run build:icon-font",
    "start": "ui5 serve --config ui5-test.yaml -o test-resources/ui5/touch/controls/Button.html",
    "check:ts": "tsc --noEmit",
    "check:lint": "eslint src test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@openui5/types": "1.149.1",
    "@ui5/cli": "latest",
    "@ui5/ts-interface-generator": "^0.11.1",
    "eslint": "10.3.0",
    "globals": "17.7.0",
    "husky": "^9.1.7",
    "rimraf": "latest",
    "svg2ttf": "^6.1.0",
    "svgicons2svgfont": "^16.0.0",
    "ttf2woff": "^3.0.0",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "ui5-middleware-livereload": "latest",
    "ui5-tooling-modules": "^3.37.7",
    "ui5-tooling-transpile": "latest",
    "wawoff2": "^2.0.1"
  },
  "packageManager": "pnpm@11.10.0"
}
