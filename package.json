{
  "name": "ui5.sized.controls",
  "version": "1.0.0",
  "description": "UI5 Library: ui5.sized.controls",
  "author": "Mario Kernich",
  "license": "Apache-2.0",
  "types": "dist/index.d.ts",
  "files": [
    ".eslintrc.js",
    "LICENCE",
    "README.md",
    "tsconfig.json",
    "ui5.yaml",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "src",
    "test"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "ui5 build --clean-dest",
    "build:ts-interfaces": "npx @ui5/ts-interface-generator",
    "start": "ui5 serve -o test-resources/ui5/sized/controls/Button.html",
    "start:dist": "npm start -- --config ui5-dist.yaml",
    "ts-typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "karma": "karma start",
    "karma-ci": "karma start karma-ci.conf.js",
    "karma-ci-cov": "karma start karma-ci-cov.conf.js",
    "test": "npm run lint && npm run karma-ci-cov"
  },
  "devDependencies": {
    "@openui5/types": "1.147.1",
    "@ui5/cli": "latest",
    "@ui5/ts-interface-generator": "^0.10.5",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "rimraf": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "ui5-middleware-livereload": "latest",
    "ui5-tooling-transpile": "latest"
  }
}
