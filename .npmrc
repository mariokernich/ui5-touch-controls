# UI5 tooling (ui5 build / serve) cannot resolve symlinked dependencies
# the way pnpm installs them by default. Hoist all UI5-related packages so
# `node_modules/@openui5/*`, `@sapui5/*` and `@ui5/*` exist as real paths.
public-hoist-pattern[]=*@openui5/*
public-hoist-pattern[]=*@sapui5/*
public-hoist-pattern[]=*@ui5/*
